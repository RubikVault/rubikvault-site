#!/usr/bin/env bash
# pre-push: ensure deploy bundle would build cleanly before allowing push to remote.
#
# Why: Cloudflare Pages auto-deploy from GitHub runs `echo "no build"` and then looks
# for dist/pages-prod/. If that directory cannot be built (missing files, exceeds
# bundle budget), the deploy fails AFTER the push — leaving main with a broken deploy.
# This hook catches it BEFORE push so deploy state stays clean.
#
# Bypass with: git push --no-verify  (use only when you know the bundle is intentionally
# incomplete, e.g. mid-cleanup commit).
#
# Install: handled automatically by `npm run prepare` which sets core.hooksPath.

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

remote="$1"
url="$2"

# Only enforce when pushing to the canonical remote main branch.
push_targets_main=0
main_local_sha=""
main_remote_sha=""
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    push_targets_main=1
    main_local_sha="$local_sha"
    main_remote_sha="$remote_sha"
  fi
done

if [ "$push_targets_main" -eq 0 ]; then
  exit 0
fi

# P4: code-manifest auto-regen.
# After Stage-2/W6/W1B/manifest-rebuild day (2026-05-02) we needed three manual
# commits to keep scripts/nas/release-truth-chain.manifest.json in sync after
# editing files in the truth chain. The supervisor's code_manifest_guard step
# fails fast if the on-disk manifest diverges, so a stale manifest can break
# the next NAS auto-run silently. Auto-regen here + fail-with-message if drift
# detected so the manifest commit can never be forgotten.
echo "[pre-push] verifying release-truth-chain manifest..."
if ! node scripts/nas/verify-code-manifest.mjs >/dev/null 2>&1; then
  echo "[pre-push] manifest drift detected — auto-regenerating..."
  node scripts/nas/verify-code-manifest.mjs --write >/dev/null 2>&1 || true
  if ! git diff --quiet -- scripts/nas/release-truth-chain.manifest.json; then
    # Auto-amend manifest into HEAD when safe:
    #   - HEAD commit younger than 5 min (fresh, same session)
    #   - HEAD not yet present on origin/main (not pushed)
    #   - Not mid-merge/rebase (no MERGE_HEAD, no rebase-apply/rebase-merge dir)
    # Eliminates manifest-commit churn that produced 10+ solo
    # 'chore(nas): regenerate release truth manifest' commits per session.
    head_age=$(( $(date +%s) - $(git log -1 --format=%ct HEAD 2>/dev/null || echo 0) ))
    head_in_remote=0
    if git fetch --quiet origin main 2>/dev/null; then
      head_in_remote=$(git branch -r --contains HEAD 2>/dev/null | grep -c origin/main || true)
    fi
    mid_merge=0
    git_dir="$(git rev-parse --git-dir 2>/dev/null || echo .git)"
    if [ -e "$git_dir/MERGE_HEAD" ] || [ -d "$git_dir/rebase-apply" ] || [ -d "$git_dir/rebase-merge" ]; then
      mid_merge=1
    fi
    if [ "$head_age" -lt 300 ] && [ "$head_in_remote" -eq 0 ] && [ "$mid_merge" -eq 0 ]; then
      echo "[pre-push] amending manifest into HEAD commit (age=${head_age}s, unpushed)..."
      git add scripts/nas/release-truth-chain.manifest.json
      if git commit --amend --no-edit --no-verify >/dev/null 2>&1; then
        echo "[pre-push] manifest amended into HEAD — continuing push."
      else
        echo "[pre-push] FAIL: amend failed unexpectedly. Manual fix required:"
        echo "[pre-push]   git add scripts/nas/release-truth-chain.manifest.json"
        echo "[pre-push]   git commit -m 'chore(nas): regenerate code-manifest'"
        exit 1
      fi
    else
      echo "[pre-push] FAIL: manifest drift (age=${head_age}s, in_remote=${head_in_remote}, mid_merge=${mid_merge})."
      echo "[pre-push] Auto-amend skipped (HEAD too old, already pushed, or mid-merge). Manual fix required:"
      echo "[pre-push]   git add scripts/nas/release-truth-chain.manifest.json"
      echo "[pre-push]   git commit -m 'chore(nas): regenerate code-manifest'"
      echo "[pre-push]   git push origin main"
      echo "[pre-push] Bypass with --no-verify only if NAS code_manifest_guard would still pass."
      exit 1
    fi
  fi
fi

echo "[pre-push] verifying deploy bundle builds cleanly (dist/pages-prod/)..."
if ! node scripts/ops/build-deploy-bundle.mjs --strict --strict-manifest >/dev/null 2>&1; then
  echo "[pre-push] FAIL: build-deploy-bundle.mjs --strict --strict-manifest failed."
  echo "[pre-push] Run \`node scripts/ops/build-deploy-bundle.mjs --strict --strict-manifest\` for details."
  echo "[pre-push] Bypass with --no-verify only if you understand the risk."
  exit 1
fi

echo "[pre-push] verifying deploy bundle has no private artifacts..."
if ! node scripts/ops/privacy-gate.mjs --dist dist/pages-prod >/dev/null 2>&1; then
  echo "[pre-push] FAIL: privacy-gate found private artifacts in dist/pages-prod."
  echo "[pre-push] Run \`node scripts/ops/privacy-gate.mjs --dist dist/pages-prod\` for details."
  echo "[pre-push] Bypass with --no-verify only if you understand the risk."
  exit 1
fi

echo "[pre-push] verifying changed paths contain no private artifacts..."
if ! node scripts/ops/privacy-gate.mjs --changed "$main_remote_sha" "$main_local_sha" >/dev/null 2>&1; then
  echo "[pre-push] FAIL: privacy-gate found private changed paths for main."
  echo "[pre-push] Run \`node scripts/ops/privacy-gate.mjs --changed $main_remote_sha $main_local_sha\` for details."
  echo "[pre-push] Bypass with --no-verify only if you understand the risk."
  exit 1
fi

echo "[pre-push] bundle ok — push allowed."
exit 0
