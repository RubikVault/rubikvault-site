public/data/status/deploy-proof-latest.json
public/data/quantlab/
public/data/v3/audit/
public/data/universe/v7/reports/
public/data/universe/v7/ssot/*report*.json
public/mirrors/
public/mirror/

# Noise: workstation-only helpers
check_dom_ids.py
fix_dashboard*.py
run_build_diag.py
test_bars*.mjs
test_dashboard.*
test_import_decisions*.mjs
test_ndx_bucket.mjs
parse-registry.mjs
scrape_ui.mjs
prod_stock.html
prod_stock-features.js
test-search.js
