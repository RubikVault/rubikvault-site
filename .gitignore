test_keys.cjs
eodhd-maximizer.mjs
new.sh
scripts/test/batch_stock_audit.mjs
scripts/ci/test_eodhd.mjs

# Noise: local config overlays
config/*.env

# Large data files — never commit (>100MB, served from CI/CDN)
public/data/features-v4/stock-insights/index.json
public/data/snapshots/stock-analysis.json
public/data/hist-probs/
public/data/hist-probs-public/
