# RubikVault .gitignore

# Never commit: secrets and local env
.env
.env.*
!.env.example
.dev.vars
*.local

# Never commit: local deploy bundle (generated by npm run build:deploy)
dist/

# Never commit: generated data and artifacts
public/data/v3/series/adjusted_all/
mirrors/forecast/ledger/**
mirrors/forecast/ops/**
mirrors/forecast/snapshots/**
mirrors/forecast/ledger/outcomes/**
mirrors/forecast/models/**
mirrors/forecast/ledgers/
mirrors/forecast/last_good/
mirrors/forecast/champion/
mirrors/quantlab/**
mirrors/universe-v7/**
mirrors/features-v2/
mirrors/learning/
public/data/features-v2/
public/data/forecast/v6/
public/data/forecast/reports/**
public/data/forecast/scorecards/tickers.json.gz
public/data/decision-core/core/parts/*.ndjson.gz
public/data/decision-core/shadow/parts/*.ndjson.gz
public/data/decision-core/last_good/parts/*.ndjson.gz
public/data/page-core/candidates/
public/data/page-core/snapshots/
public/data/eod/bars/*.json
public/data/universe_spy50.json
public/data/v3/derived/market/flow-learning.json
public/data/v3/eod/US/etf-proxies.json
artifacts/
.artifacts/
coverage/
test-results/
test-results/**
.last-run.json
.wrangler-pages-build-current/
tmp/
.tmp/
logs/
runtime/decision-runs/
runtime/outcomes/
var/pipeline/
mirrors/.locks/
proof.html
public/proof.html
Report/ProtectionAudit/
Report/A/
dev/Report10/**
public/dashboard_v6_meta_data.*.json

# Never commit: local runtime caches
**/.cache/wrangler/
**/.wrangler/
.mf/
quantlab/.pytest_cache/**
quantlab/.ruff_cache/**
quantlab/src/quantlab.egg-info/**
quantlab/data/**
quantlab/runs/**
quantlab/jobs/**
quantlab/ops/**
quantlab/registry/**
quantlab/models/**
quantlab/artifacts/**

# Allow tracked RVCI outputs, hide everything else in the folder
public/data/rvci/*
!public/data/rvci/
!public/data/rvci/rvci_top_short.json
!public/data/rvci/rvci_top_mid.json
!public/data/rvci/rvci_top_long.json
!public/data/rvci/rvci_triggers.json
!public/data/rvci/health.json

# Noise: dependency installs, editor caches, local tooling
node_modules/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.venv*/
venv/
**/__pycache__/
*.pyc
**/.DS_Store
.claude/
.playwright-cli/
.playwright-mcp/
.vscode/
.idea/
.cursor/
.cursorrules
_local_trash/
_pre_codex_dirty.diff
diff.txt
nohup.out
*.tmp
*.log
*.bak

# Noise: local debug and backup paths
functions/api/_debug-trace.js
functions/api/_bak/
functions/api/_bak/**
debug/
internal/
rubikvault-site/
.github/workflows/*.bak.*

# Private public/ artifacts: local/NAS only, never deploy or newly track
var/private/
public/debug/
public/internal/
public/ops/
public/mission-control*/
public/internal-dashboard*
public/dashboard*.html
public/dashboard_v*/
public/dashboard_v6_meta_data*.json
