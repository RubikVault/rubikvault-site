{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Breakout V1.2 Outcome Row",
  "type": "object",
  "required": [
    "event_id",
    "signal_date",
    "horizon",
    "entry_price",
    "target_price",
    "stop_price",
    "first_touch",
    "target_hit",
    "stop_hit",
    "time_stop",
    "gap_event",
    "overlap_suppressed"
  ],
  "additionalProperties": true,
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "signal_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "horizon": { "type": "integer", "minimum": 1 },
    "entry_price": { "type": "number" },
    "target_price": { "type": "number" },
    "stop_price": { "type": "number" },
    "first_touch": { "type": "string", "enum": ["target", "stop", "time", "none", "missing_forward_data"] },
    "target_hit": { "type": "boolean" },
    "stop_hit": { "type": "boolean" },
    "time_stop": { "type": "boolean" },
    "mfe_atr": { "type": ["number", "null"] },
    "mae_atr": { "type": ["number", "null"] },
    "gap_event": { "type": "boolean" },
    "overlap_suppressed": { "type": "boolean" },
    "benchmark_adjusted_return": { "type": ["number", "null"] }
  }
}
