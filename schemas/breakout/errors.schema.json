{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Breakout V1.2 Errors",
  "type": "object",
  "required": ["schema_version", "as_of", "errors"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "const": "breakout_errors_v1" },
    "as_of": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "asset_id": { "type": ["string", "null"] },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  }
}
