{
  "$id": "rv.historical_setups_today.v1",
  "type": "object",
  "required": ["schema", "generated_at", "regions"],
  "properties": {
    "schema": { "const": "rv.historical_setups_today.v1" },
    "generated_at": { "type": "string" },
    "regions": {
      "type": "object",
      "required": ["US", "EU", "ASIA"],
      "properties": {
        "US": { "$ref": "#/$defs/region" },
        "EU": { "$ref": "#/$defs/region" },
        "ASIA": { "$ref": "#/$defs/region" }
      }
    },
    "leaderboards": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/assetClassMap" }
    }
  },
  "$defs": {
    "assetClassMap": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/region" }
    },
    "region": {
      "type": "object",
      "required": ["long", "short"],
      "properties": {
        "long": { "type": "array", "items": { "$ref": "#/$defs/setup" } },
        "short": { "type": "array", "items": { "$ref": "#/$defs/setup" } }
      }
    },
    "setup": {
      "type": "object",
      "required": ["asset_id", "ticker", "direction", "pattern_id", "rank_score"],
      "properties": {
        "asset_id": { "type": "string" },
        "ticker": { "type": "string" },
        "asset_class": { "enum": ["STOCK", "ETF", "INDEX"] },
        "region": { "enum": ["US", "EU", "ASIA"] },
        "direction": { "enum": ["LONG", "SHORT"] },
        "pattern_id": { "type": "string" },
        "rank_score": { "type": "number" },
        "rank_probability": { "type": ["number", "null"] },
        "expected_gain_pct": { "type": ["number", "null"] },
        "sample_size": { "type": ["number", "null"] },
        "route": { "type": "string" },
        "explanation": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
