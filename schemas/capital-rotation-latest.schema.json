{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Capital Rotation Latest",
  "type": "object",
  "required": ["schema_version", "metadata", "data"],
  "properties": {
    "schema_version": { "type": "string" },
    "metadata": {
      "type": "object",
      "required": ["module"],
      "properties": {
        "module": { "const": "capital-rotation" },
        "tier": { "type": "string" },
        "domain": { "type": "string" },
        "source": { "type": "string" },
        "fetched_at": { "type": "string" },
        "published_at": { "type": "string" },
        "digest": {},
        "record_count": { "type": "integer" },
        "params_version": { "type": "string" },
        "score_version": { "type": "string" }
      }
    },
    "data": {
      "type": "object",
      "required": ["globalScore", "blocks", "cycle", "narrative", "ratios", "meta"],
      "properties": {
        "globalScore": {
          "type": "object",
          "required": ["value", "regime", "confidence", "confidenceLabel"],
          "properties": {
            "value": { "type": "number", "minimum": 0, "maximum": 100 },
            "regime": { "type": "string" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "confidenceLabel": { "enum": ["High", "Medium", "Mixed", "Low"] },
            "neutralMode": { "enum": ["none", "quiet", "conflicted"] }
          }
        },
        "blocks": {
          "type": "object",
          "patternProperties": {
            ".*": {
              "type": "object",
              "properties": {
                "score": { "type": "number", "minimum": 0, "maximum": 100 },
                "count": { "type": "integer" },
                "available": { "type": "integer" },
                "label": { "type": "string" }
              }
            }
          }
        },
        "cycle": {
          "type": "object",
          "properties": {
            "positionPct": { "type": "number" },
            "state": { "type": "string" },
            "confidence": { "type": "number" },
            "description": { "type": "string" }
          }
        },
        "confirmations": { "type": "object" },
        "divergences": { "type": "array" },
        "narrative": {
          "type": "object",
          "required": ["headline", "blocks"],
          "properties": {
            "headline": { "type": "string", "minLength": 1 },
            "blocks": { "type": "array", "items": { "type": "string" } },
            "generatedAt": { "type": "string" }
          }
        },
        "ratios": {
          "type": "object",
          "patternProperties": {
            ".*": {
              "type": "object",
              "properties": {
                "composite": { "type": ["number", "null"] },
                "category": { "type": "string" },
                "status": { "type": "string" }
              }
            }
          }
        },
        "keyCards": { "type": "array" },
        "sectorRelative": { "type": "object" },
        "meta": {
          "type": "object",
          "required": ["status", "coverage", "staleStatus", "asOfDate"],
          "properties": {
            "status": { "enum": ["ok", "partial", "stale", "error"] },
            "coverage": { "type": "number", "minimum": 0, "maximum": 1 },
            "staleStatus": { "enum": ["fresh", "stale", "critical_stale"] },
            "warnings": { "type": "array", "items": { "type": "string" } },
            "asOfDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "timezone": { "type": "string" },
            "tradingCalendar": { "type": "string" },
            "dataSourcesUsed": { "type": "array" },
            "paramsVersion": { "type": "string" },
            "returnType": { "type": "string" }
          }
        }
      }
    }
  }
}
