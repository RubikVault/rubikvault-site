{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "as_of", "status", "hard_fail", "alert"],
  "properties": {
    "schema_version": { "const": "breakout_health_v1" },
    "as_of": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "generated_at": { "type": "string" },
    "status": { "type": "string", "enum": ["ok", "warning", "degraded", "failed"] },
    "hard_fail": { "type": "boolean" },
    "alert": { "type": "boolean" }
  },
  "additionalProperties": true
}
