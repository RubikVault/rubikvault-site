{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "run_id", "as_of", "status", "paths"],
  "properties": {
    "schema_version": { "const": "breakout_v12_incremental_manifest_v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "as_of": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "status": { "type": "string", "enum": ["candidate", "promoted", "failed"] },
    "paths": { "type": "object" },
    "counts": { "type": "object" },
    "hashes": { "type": "object" }
  },
  "additionalProperties": true
}
