{
  "version": 2,
  "_comment": "Visitor-runtime allowlist. Deploy bundle is deny-by-default; private ops, dashboards, reports, logs, lessons, pipeline state, diagnostics, and architecture notes must never match an allow rule.",
  "defaults": {
    "maxFileSizeBytes": 26214400
  },
  "required": [
    { "path": "index.html", "maxFileSizeBytes": 2097152 },
    { "path": "stock.html", "maxFileSizeBytes": 2097152 },
    { "path": "data/public-status.json", "maxFileSizeBytes": 16384 }
  ],
  "allow": [
    { "pattern": "index.html", "maxFileSizeBytes": 2097152, "class": "visitor-html" },
    { "pattern": "stock.html", "maxFileSizeBytes": 2097152, "class": "visitor-html" },
    { "pattern": "forecast.html", "maxFileSizeBytes": 2097152, "class": "visitor-html" },
    { "pattern": "scientific.html", "maxFileSizeBytes": 2097152, "class": "visitor-html" },
    { "pattern": "elliott.html", "maxFileSizeBytes": 2097152, "class": "visitor-html" },
    { "pattern": "breakout-all.html", "maxFileSizeBytes": 2097152, "class": "visitor-html" },
    { "pattern": "breakout-test.html", "maxFileSizeBytes": 2097152, "class": "visitor-html" },
    { "pattern": "market-stats.html", "maxFileSizeBytes": 2097152, "class": "visitor-html" },
    { "pattern": "showcase.html", "maxFileSizeBytes": 2097152, "class": "visitor-html" },
    { "pattern": "dashboard_v7.html", "maxFileSizeBytes": 1048576, "class": "public-dashboard", "allowDenyNameHints": true },
    { "pattern": "dashboard_v7/index.html", "maxFileSizeBytes": 1048576, "class": "public-dashboard", "allowDenyNameHints": true },
    { "pattern": "404.html", "maxFileSizeBytes": 2097152, "class": "visitor-html" },

    { "pattern": "_headers", "maxFileSizeBytes": 102400, "class": "cf-config" },
    { "pattern": "_redirects", "maxFileSizeBytes": 102400, "class": "cf-config" },
    { "pattern": "_routes.json", "maxFileSizeBytes": 102400, "class": "cf-config" },
    { "pattern": "robots.txt", "maxFileSizeBytes": 10240, "class": "web-standard" },
    { "pattern": "favicon.*", "maxFileSizeBytes": 102400, "class": "web-standard" },
    { "pattern": "__redirects_canary", "maxFileSizeBytes": 1024, "class": "cf-config" },
    { "pattern": "manifest.json", "maxFileSizeBytes": 10240, "class": "pwa-manifest" },
    { "pattern": "service-worker.js", "maxFileSizeBytes": 1048576, "class": "pwa-sw" },
    { "pattern": "feature-registry.json", "maxFileSizeBytes": 102400, "class": "feature-registry" },
    { "pattern": "*.css", "maxFileSizeBytes": 1048576, "class": "root-css" },
    { "pattern": "market-clock.js", "maxFileSizeBytes": 1048576, "class": "root-js" },
    { "pattern": "search.js", "maxFileSizeBytes": 1048576, "class": "root-js" },
    { "pattern": "rv-loader.js", "maxFileSizeBytes": 1048576, "class": "root-js" },
    { "pattern": "rv-config.js", "maxFileSizeBytes": 1048576, "class": "root-js" },

    { "pattern": "assets/**", "maxFileSizeBytes": 5242880, "class": "asset" },
    { "pattern": "images/**", "maxFileSizeBytes": 5242880, "class": "image" },
    { "pattern": "js/**", "maxFileSizeBytes": 5242880, "class": "app-js" },
    { "pattern": "src/**", "maxFileSizeBytes": 5242880, "class": "src-asset" },
    { "pattern": "features/**", "maxFileSizeBytes": 5242880, "class": "feature-asset" },
    { "pattern": "config/*.json", "maxFileSizeBytes": 102400, "class": "site-config" },
    { "pattern": "content/**", "maxFileSizeBytes": 524288, "class": "visitor-content" },
    { "pattern": "posts/**", "maxFileSizeBytes": 1048576, "class": "visitor-posts" },

    { "pattern": "data/public-status.json", "maxFileSizeBytes": 16384, "class": "public-status" },
    { "pattern": "data/status/deploy-proof-latest.json", "maxFileSizeBytes": 16384, "class": "public-deploy-proof", "allowDenyNameHints": true },
    { "pattern": "data/status/dashboard-v7-public-latest.json", "maxFileSizeBytes": 262144, "class": "public-dashboard-status", "allowDenyNameHints": true },
    { "pattern": "data/status/decision-module-scorecard-latest.json", "maxFileSizeBytes": 262144, "class": "decision-module-scorecard" },
    { "pattern": "data/reports/decision-core-buy-breadth-latest.json", "maxFileSizeBytes": 65536, "class": "decision-core-public-proof", "allowDenyNameHints": true },
    { "pattern": "data/reports/stock-decision-core-ui-buy-breadth-latest.json", "maxFileSizeBytes": 65536, "class": "decision-core-public-proof", "allowDenyNameHints": true },
    { "pattern": "data/reports/stock-decision-core-ui-random20-latest.json", "maxFileSizeBytes": 65536, "class": "decision-core-public-proof", "allowDenyNameHints": true },
    { "pattern": "data/reports/frontpage-best-setups-ui-proof-latest.json", "maxFileSizeBytes": 524288, "class": "decision-core-public-proof", "allowDenyNameHints": true },
    { "pattern": "data/reports/decision-core-historical-replay-latest.json", "maxFileSizeBytes": 131072, "class": "decision-core-public-proof", "allowDenyNameHints": true },
    { "pattern": "data/reports/decision-core-outcome-bootstrap-latest.json", "maxFileSizeBytes": 16384, "class": "decision-core-public-proof", "allowDenyNameHints": true },
    { "pattern": "data/runtime/hist-probs-status-summary.json", "maxFileSizeBytes": 65536, "class": "hist-probs-public-status" },
    { "pattern": "data/runtime/stock-analyzer-ui-delivery.json", "maxFileSizeBytes": 262144, "class": "stock-analyzer-public-delivery-status" },
    { "pattern": "data/runtime/stock-analyzer-provider-exceptions-latest.json", "maxFileSizeBytes": 131072, "class": "stock-analyzer-public-provider-exceptions" },
    { "pattern": "data/eod/history/pack-manifest.us-eu.json", "maxFileSizeBytes": 20971520, "class": "eod-pack-manifest" },
    { "pattern": "data/eod/history/pack-manifest.us-eu.lookup.json", "maxFileSizeBytes": 10485760, "class": "eod-pack-manifest-lookup" },
    { "pattern": "data/eod/history/shards/*.json", "maxFileSizeBytes": 1048576, "class": "eod-shard" },
    { "pattern": "data/eod/history/shards/*.json.gz", "maxFileSizeBytes": 26214400, "class": "eod-public-chart-shard" },
    { "pattern": "data/eod/batches/*.json", "maxFileSizeBytes": 2097152, "class": "eod-batch" },
    { "pattern": "data/eod/manifest.latest.json", "maxFileSizeBytes": 524288, "class": "eod-manifest" },
    { "pattern": "data/v3/**", "maxFileSizeBytes": 5242880, "class": "v3-public-data" },
    { "pattern": "data/symbol-resolve.v1.json", "maxFileSizeBytes": 20971520, "class": "symbol-resolve" },
    { "pattern": "data/symbol-resolve.v1.lookup.json", "maxFileSizeBytes": 10485760, "class": "symbol-resolve-lookup" },
    { "pattern": "data/universe/**", "maxFileSizeBytes": 26214400, "class": "universe-public-data" },
    { "pattern": "data/supermodules/*.json", "maxFileSizeBytes": 5242880, "class": "public-supermodule" },
    { "pattern": "data/snapshots/**", "maxFileSizeBytes": 20971520, "class": "public-snapshot" },
    { "pattern": "data/forecast/latest.json", "maxFileSizeBytes": 20971520, "class": "public-forecast" },
    { "pattern": "data/forecast/last_good.json", "maxFileSizeBytes": 20971520, "class": "public-forecast" },
    { "pattern": "data/forecast/system/*.json", "maxFileSizeBytes": 20971520, "class": "public-forecast-status" },
    { "pattern": "data/forecast/models/registry.json", "maxFileSizeBytes": 524288, "class": "public-forecast-models" },
    { "pattern": "data/forecast/scorecards/tickers.json.gz", "maxFileSizeBytes": 524288, "class": "public-forecast-scorecards" },
    { "pattern": "data/fundamentals/**", "maxFileSizeBytes": 2097152, "class": "public-fundamentals" },
    { "pattern": "data/models/**", "maxFileSizeBytes": 524288, "class": "public-model-metadata" },
    { "pattern": "data/earnings-calendar/**", "maxFileSizeBytes": 2097152, "class": "public-earnings" },
    { "pattern": "data/page-core/latest.json", "maxFileSizeBytes": 4096, "class": "page-core-pointer" },
    { "pattern": "data/page-core/candidates/*.json", "maxFileSizeBytes": 8192, "class": "page-core-candidate" },
    { "pattern": "data/page-core/snapshots/**/manifest.json", "maxFileSizeBytes": 65536, "class": "page-core-manifest" },
    { "pattern": "data/page-core/snapshots/**/alias-shards/*.json.gz", "maxFileSizeBytes": 524288, "class": "page-core-alias-shard" },
    { "pattern": "data/page-core/snapshots/**/page-shards/*.json.gz", "maxFileSizeBytes": 1048576, "class": "page-core-page-shard" },
    { "pattern": "data/decision-core/core/manifest.json", "maxFileSizeBytes": 131072, "class": "decision-core-manifest" },
    { "pattern": "data/decision-core/core/status.json", "maxFileSizeBytes": 131072, "class": "decision-core-status" },
    { "pattern": "data/decision-core/core/parts/*.ndjson.gz", "maxFileSizeBytes": 1048576, "class": "decision-core-part" },
    { "pattern": "data/decision-core/shadow/manifest.json", "maxFileSizeBytes": 131072, "class": "decision-core-shadow-manifest" },
    { "pattern": "data/decision-core/shadow/status.json", "maxFileSizeBytes": 131072, "class": "decision-core-shadow-status" },
    { "pattern": "data/decision-core/shadow/parts/*.ndjson.gz", "maxFileSizeBytes": 1048576, "class": "decision-core-shadow-part" },
    { "pattern": "data/decision-core/last_good/manifest.json", "maxFileSizeBytes": 131072, "class": "decision-core-last-good-manifest" },
    { "pattern": "data/decision-core/last_good/status.json", "maxFileSizeBytes": 131072, "class": "decision-core-last-good-status" },
    { "pattern": "data/decision-core/last_good/parts/*.ndjson.gz", "maxFileSizeBytes": 1048576, "class": "decision-core-last-good-part" },
    { "pattern": "data/decision-core/policies/latest.json", "maxFileSizeBytes": 131072, "class": "decision-core-policy" },
    { "pattern": "data/decision-core/reason-codes/latest.json", "maxFileSizeBytes": 262144, "class": "decision-core-reason-codes" },
    { "pattern": "data/decision-core/feature-manifests/latest.json", "maxFileSizeBytes": 131072, "class": "decision-core-feature-manifest" },
    { "pattern": "data/decision-core/status/latest.json", "maxFileSizeBytes": 131072, "class": "decision-core-public-status" },
    { "pattern": "data/decision-core/status/accelerated-certification-latest.json", "maxFileSizeBytes": 131072, "class": "decision-core-accelerated-certification" },
    { "pattern": "data/decision-core/status/shadow-ledger-latest.json", "maxFileSizeBytes": 131072, "class": "decision-core-shadow-ledger" },
    { "pattern": "data/decision-core/status/universe-summary-latest.json", "maxFileSizeBytes": 1048576, "class": "decision-core-universe-summary" },
    { "pattern": "data/decision-core/shadow-diff-latest.json", "maxFileSizeBytes": 131072, "class": "decision-core-shadow-diff" },
    { "pattern": "data/hist-probs-public/latest.json", "maxFileSizeBytes": 4096, "class": "hist-probs-public-pointer" },
    { "pattern": "data/hist-probs-public/manifest.json", "maxFileSizeBytes": 1048576, "class": "hist-probs-public-manifest" },
    { "pattern": "data/hist-probs-public/shards/*.json", "maxFileSizeBytes": 6291456, "class": "hist-probs-public-shard" },
    { "pattern": "data/breakout/status.json", "maxFileSizeBytes": 65536, "class": "breakout-v12-status" },
    { "pattern": "data/breakout/manifests/*.json", "maxFileSizeBytes": 65536, "class": "breakout-v12-manifest-pointer" },
    { "pattern": "data/breakout/reports/validity/*.json", "maxFileSizeBytes": 262144, "class": "breakout-v12-validity-report" },
    { "pattern": "data/breakout/runs/**/manifest.json", "maxFileSizeBytes": 65536, "class": "breakout-v12-run-manifest" },
    { "pattern": "data/breakout/runs/**/coverage.json", "maxFileSizeBytes": 262144, "class": "breakout-v12-run-health" },
    { "pattern": "data/breakout/runs/**/errors.json", "maxFileSizeBytes": 262144, "class": "breakout-v12-run-health" },
    { "pattern": "data/breakout/runs/**/health.json", "maxFileSizeBytes": 262144, "class": "breakout-v12-run-health" },
    { "pattern": "data/breakout/runs/**/metadata.json", "maxFileSizeBytes": 262144, "class": "breakout-v12-run-metadata" },
    { "pattern": "data/breakout/runs/**/legacy-comparison.json", "maxFileSizeBytes": 262144, "class": "breakout-v12-run-metadata" },
    { "pattern": "data/breakout/runs/**/top500.json", "maxFileSizeBytes": 5242880, "class": "breakout-v12-top500" },
    { "pattern": "data/breakout/runs/**/state-summary.json", "maxFileSizeBytes": 65536, "class": "breakout-v12-state-summary" },
    { "pattern": "data/breakout/runs/**/all_scored.json", "maxFileSizeBytes": 16777216, "class": "breakout-v12-all-scored" },
    { "pattern": "data/breakout/runs/**/shards/**/*.json", "maxFileSizeBytes": 5242880, "class": "breakout-v12-shard" },
    { "pattern": "data/breakout/runs/**/shards/**/shard_*._SUCCESS", "maxFileSizeBytes": 1024, "class": "breakout-v12-shard-marker" },
    { "pattern": "data/features-v4/**", "maxFileSizeBytes": 10485760, "class": "public-features-v4" },

    { "pattern": "deploy-probe-*.txt", "maxFileSizeBytes": 1024, "class": "probe" }
  ],
  "denyNameHints": [
    "audit",
    "dashboard",
    "debug",
    "deep-summary",
    "diagnose",
    "diagnostic",
    "full-audit",
    "internal",
    "lesson",
    "mission-control",
    "ops",
    "pipeline",
    "proof",
    "raw-export",
    "report",
    "rescue-all",
    "runblock",
    "runbook",
    "seal"
  ]
}
